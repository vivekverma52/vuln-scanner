# ─── VulnScan Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and customize

# Where uploaded files are saved on disk.
# Windows example: UPLOAD_DIR=C:\VulnScanner\uploads
# Linux/Mac example: UPLOAD_DIR=/home/user/vuln-uploads
# Default (if not set): ./uploads inside the Next.js project root
UPLOAD_DIR=./uploads

# Full path to your Python vulnerability agent script.
# The script must accept: python agent.py --file <filepath>
# and print JSON to stdout matching the ScanResult schema.
# Default: ./agent/vuln_agent.py
PYTHON_AGENT_PATH=./agent/vuln_agent.py

# Python binary name (useful if you use a venv)
# Default: python
PYTHON_BIN=python
